{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/The10thHunter/alexandria-sdk/main/schemas/atool.schema.json",
  "title": "Alexandria atool manifest",
  "description": "Manifest for .atool and .aagent packages (EE-canonical schema v2). Source of truth across all SDKs and the LSP. Kinds and field names mirror ee/crates/alex-package/src/manifest.rs.",
  "type": "object",
  "required": ["schema_version", "name", "version", "kind", "description", "config"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "2" },
    "name": {
      "type": "string",
      "pattern": "^([a-z0-9][a-z0-9_-]*/)?[a-z0-9][a-z0-9_-]*$",
      "description": "'vendor/name' or 'name'."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+].+)?$",
      "description": "SemVer."
    },
    "kind": {
      "enum": ["mcp", "atool", "aagent"]
    },
    "description": { "type": "string", "minLength": 1 },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "requires_alexandria": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependency" }
    },
    "extends": {
      "type": "array",
      "description": "Base packages this aagent extends. aagent-only.",
      "items": { "$ref": "#/$defs/packageDep" }
    },
    "lockfile": {
      "type": "array",
      "description": "Resolved inheritance lockfile (aagent-only).",
      "items": { "$ref": "#/$defs/lockEntry" }
    },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/file" }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provides_tools": { "type": "array", "items": { "type": "string" } },
        "needs_tools": { "type": "array", "items": { "type": "string" } },
        "suggested_role": { "type": "string" }
      }
    },
    "config": {
      "oneOf": [
        { "$ref": "#/$defs/mcpConfig" },
        { "$ref": "#/$defs/atoolConfig" },
        { "$ref": "#/$defs/aagentConfig" }
      ]
    },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentItem" }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flatten": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "system_prompt": { "enum": ["concat", "root_wins", "error_on_conflict"] },
            "allowed_tools": { "enum": ["union", "root_wins"] },
            "model": { "const": "root_wins" },
            "history_limit": { "const": "root_wins" }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "required": ["alg", "key_fingerprint", "value", "scope"],
      "additionalProperties": false,
      "properties": {
        "alg": { "type": "string" },
        "key_fingerprint": { "type": "string" },
        "value": { "type": "string" },
        "scope": { "enum": ["bundle", "per_component"] }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "kind": { "const": "mcp" } },
        "required": ["kind"]
      },
      "then": {
        "properties": {
          "config": { "$ref": "#/$defs/mcpConfig" },
          "extends": { "maxItems": 0 }
        },
        "not": { "required": ["components"] }
      }
    },
    {
      "if": {
        "properties": { "kind": { "const": "atool" } },
        "required": ["kind"]
      },
      "then": {
        "properties": {
          "config": { "$ref": "#/$defs/atoolConfig" },
          "extends": { "maxItems": 0 }
        },
        "not": { "required": ["components"] }
      }
    },
    {
      "if": {
        "properties": { "kind": { "const": "aagent" } },
        "required": ["kind"]
      },
      "then": {
        "properties": { "config": { "$ref": "#/$defs/aagentConfig" } }
      }
    }
  ],
  "$defs": {
    "dependency": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "packageDep": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string" }
      }
    },
    "lockEntry": {
      "type": "object",
      "required": ["name", "interface_major"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "interface_major": { "type": "integer", "minimum": 0 },
        "contract_hash": { "type": "string" }
      }
    },
    "credentialDecl": {
      "type": "object",
      "description": "Author-time DECLARATION of a secret env var a spawnable tool reads. Never carries a secret value — the operator binds the value into the deployment-shape secret backend at install time; the DB row holds only a ref.",
      "required": ["env"],
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "description": "Exact env var name THIS tool reads for the secret (POSIX-ish)."
        },
        "secret": { "type": "boolean", "default": true },
        "required": { "type": "boolean", "default": false },
        "description": { "type": "string" },
        "rotation": {
          "enum": ["respawn", "oauth-refresh"],
          "default": "respawn",
          "description": "How a rotated secret is re-injected. 'oauth-refresh' is declare-only for now."
        }
      }
    },
    "envDecl": {
      "type": "object",
      "description": "Author-time DECLARATION of a non-secret config env var. May carry a literal default; the operator-time binding stores its value inline (name -> value), not as a secret ref.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "description": "Env var name the tool reads (POSIX-ish)."
        },
        "default": { "type": "string" },
        "required": { "type": "boolean", "default": false }
      }
    },
    "file": {
      "type": "object",
      "required": ["archive_path", "install_path"],
      "additionalProperties": false,
      "properties": {
        "archive_path": { "type": "string", "minLength": 1 },
        "install_path": { "type": "string", "minLength": 1 },
        "executable": { "type": "boolean", "default": false },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{0,64}$" }
      }
    },
    "k8sResources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "mcpConfig": {
      "type": "object",
      "required": ["kind", "binary"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "mcp" },
        "binary": { "type": "string", "minLength": 1 },
        "default_port": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "transport": { "enum": ["http", "sse"] },
        "args": { "type": "array", "items": { "type": "string" } },
        "interface_major": { "type": "integer", "minimum": 1 },
        "k8s_image": { "type": "string" },
        "k8s_capabilities": { "type": "array", "items": { "type": "string" } },
        "k8s_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "k8s_transport": { "enum": ["grpc", "http", "sse"] },
        "k8s_resources": { "$ref": "#/$defs/k8sResources" },
        "k8s_min_warm": { "type": "integer", "minimum": 0 },
        "k8s_idle_timeout_seconds": { "type": "integer", "minimum": 0 },
        "credentials": {
          "type": "array",
          "description": "Author-time credential declarations (secret env vars this tool reads). No secret values ever appear here.",
          "items": { "$ref": "#/$defs/credentialDecl" }
        },
        "env": {
          "type": "array",
          "description": "Author-time non-secret config env declarations (name -> default).",
          "items": { "$ref": "#/$defs/envDecl" }
        }
      }
    },
    "atoolConfig": {
      "type": "object",
      "required": ["kind", "binary"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "atool" },
        "binary": { "type": "string", "minLength": 1 },
        "default_port": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "transport": { "enum": ["grpc", "http", "sse"] },
        "args": { "type": "array", "items": { "type": "string" } },
        "interface_major": { "type": "integer", "minimum": 1 },
        "k8s_image": { "type": "string" },
        "k8s_capabilities": { "type": "array", "items": { "type": "string" } },
        "k8s_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "k8s_transport": { "enum": ["grpc", "http", "sse"] },
        "k8s_resources": { "$ref": "#/$defs/k8sResources" },
        "k8s_min_warm": { "type": "integer", "minimum": 0 },
        "k8s_idle_timeout_seconds": { "type": "integer", "minimum": 0 },
        "credentials": {
          "type": "array",
          "description": "Author-time credential declarations (secret env vars this tool reads). No secret values ever appear here.",
          "items": { "$ref": "#/$defs/credentialDecl" }
        },
        "env": {
          "type": "array",
          "description": "Author-time non-secret config env declarations (name -> default).",
          "items": { "$ref": "#/$defs/envDecl" }
        }
      }
    },
    "aagentConfig": {
      "type": "object",
      "required": ["kind", "system_prompt"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "aagent" },
        "system_prompt": { "type": "string", "minLength": 1 },
        "allowed_tools": { "type": "array", "items": { "type": "string" } },
        "model": { "type": "string" },
        "history_limit": { "type": "integer", "minimum": 1 },
        "prompt_mode": { "enum": ["append", "replace"] }
      }
    },
    "componentItem": {
      "oneOf": [
        {
          "type": "object",
          "required": ["ref"],
          "additionalProperties": false,
          "properties": {
            "ref": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["name", "id", "kind", "config"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "id": {
              "type": "string",
              "pattern": "^([a-z0-9][a-z0-9_-]*/)?[a-z0-9][a-z0-9_-]*@\\d+\\.\\d+\\.\\d+",
              "description": "Canonical ns/name@version used for coalescing."
            },
            "kind": { "const": "aagent" },
            "config": { "$ref": "#/$defs/aagentConfig" },
            "components": {
              "type": "array",
              "items": { "$ref": "#/$defs/componentItem" }
            },
            "files": {
              "type": "array",
              "items": { "$ref": "#/$defs/file" }
            },
            "permissions": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "provides_tools": { "type": "array", "items": { "type": "string" } },
                "needs_tools": { "type": "array", "items": { "type": "string" } },
                "suggested_role": { "type": "string" }
              }
            },
            "dependencies": {
              "type": "array",
              "items": { "$ref": "#/$defs/dependency" }
            }
          }
        }
      ]
    }
  }
}
