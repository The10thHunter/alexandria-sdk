#!/usr/bin/env python3
"""Alexandria tool daemon (Python scaffold).

Alexandria starts this on `alexandria tool start my-tool` and expects an
MCP-compatible HTTP/SSE endpoint on config.default_port.
"""
import os
import signal
import time

print(f"my-tool listening on {os.environ.get('PORT', 7800)}", flush=True)
signal.signal(signal.SIGTERM, lambda *_: exit(0))
while True:
    time.sleep(3600)
